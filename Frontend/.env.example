# ============================================
# VITE ENVIRONMENT CONFIGURATION
# ============================================
# Vite prefixes environment variables with VITE_ to expose them to the browser

# ============================================
# API CONFIGURATION
# ============================================
# --- Local Development ---
# Point to your local backend server
# VITE_API_BASE_URL=http://localhost:8080

# --- Production (Render) ---
# Auto-populated from render.yaml: backend's RENDER_EXTERNAL_URL
# Example: https://sigmagpt-backend.onrender.com
# IMPORTANT: No trailing slash
VITE_API_BASE_URL=https://YOUR-BACKEND-SERVICE.onrender.com

# ============================================
# OPTIONAL: TYPING SPEED (milliseconds)
# ============================================
# Control the streaming text animation speed (default: 40ms per word)
# Lower = faster typing, Higher = slower typing
# VITE_TYPING_SPEED=40

# ============================================
# PRODUCTION CHECKLIST
# ============================================
# Before deploying:
# ✓ VITE_API_BASE_URL matches your backend domain
# ✓ No trailing slash in VITE_API_BASE_URL
# ✓ Use https:// for production
# ✓ Never commit sensitive data to this file

