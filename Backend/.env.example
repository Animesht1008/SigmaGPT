# --- Local dev ---
# PORT=8080
# MONGODB_URI=mongodb://127.0.0.1:27017/sigmagpt

# --- Atlas (production) — use your SRV string; include DB name before ? e.g. /sigmagpt ---
# Example: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/sigmagpt?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xnqeeoj.mongodb.net/sigmagpt?retryWrites=true&w=majority&appName=Cluster0

OPENAI_API_KEY=your_key_here
MOCK_OPENAI=false

# CORS: deployed frontend URL(s)
# CORS_ORIGIN=http://localhost:5173
CORS_ORIGIN=https://YOUR-FRONTEND-SERVICE.onrender.com

ENABLE_TEST_ENDPOINT=false
