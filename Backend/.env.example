# ============================================
# ENVIRONMENT CONFIGURATION
# ============================================
# NODE_ENV: Set to 'production' when deploying
NODE_ENV=development

# ============================================
# DATABASE (MongoDB)
# ============================================
# --- Local Development ---
# MONGODB_URI=mongodb://127.0.0.1:27017/sigmagpt

# --- Production (MongoDB Atlas) ---
# Use your SRV connection string with password URL-encoded
# Format: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/sigmagpt?retryWrites=true&w=majority
# IMPORTANT: Include the database name (/sigmagpt) before the query string
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xnqeeoj.mongodb.net/sigmagpt?retryWrites=true&w=majority&appName=Cluster0

# ============================================
# AI PROVIDER (OpenAI)
# ============================================
# Your OpenAI API key (get from https://platform.openai.com/account/api-keys)
OPENAI_API_KEY=your_key_here

# Set to 'true' for local development/testing without OpenAI API key
# IMPORTANT: Set to 'false' in production to use real OpenAI API
MOCK_OPENAI=false

# ============================================
# SECURITY & CORS
# ============================================
# --- Local Development ---
# CORS_ORIGIN=http://localhost:5173

# --- Production ---
# Set to your frontend domain (comma-separated for multiple origins)
# CRITICAL: Configure this in production for security
# Examples:
#   Single origin: https://yourapp.onrender.com
#   Multiple origins: https://app.example.com,https://www.example.com
CORS_ORIGIN=https://YOUR-FRONTEND-SERVICE.onrender.com

# ============================================
# FEATURES
# ============================================
# Enable /api/test endpoint (disabled by default for security)
ENABLE_TEST_ENDPOINT=false

# ============================================
# SERVER
# ============================================
# Server port (default: 8080)
# PORT=8080

# ============================================
# PRODUCTION CHECKLIST
# ============================================
# Before deploying:
# ✓ Set NODE_ENV=production
# ✓ Set OPENAI_API_KEY to real key (and MOCK_OPENAI=false)
# ✓ Set MONGODB_URI to production Atlas URI
# ✓ Set CORS_ORIGIN to actual frontend domain
# ✓ Keep ENABLE_TEST_ENDPOINT=false
# ✓ Never commit this .env file to git

